# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Env
.env

# Data & cache
data/cache/
# NOTE: the LLM bar-keyed cache (cache/llm/) is intentionally TRACKED in git so
# that seminar replays are free, deterministic, and offline-capable (spec §6).
# Do NOT add cache/llm/ to ignores.
results/runs/
results/plots/

# Allow committed test fixtures
!tests/fixtures/
!tests/fixtures/**

# Build / tool artifacts
.coverage
.coverage.*
htmlcov/
uv.lock

# OS
.DS_Store
Thumbs.db
